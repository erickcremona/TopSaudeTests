@page
@model TopSaudeDashboard.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 align-items-end mb-2">
    <div class="col-md-3">
        <label class="form-label">Período (dias)</label>
        <select class="form-select" id="periodDays">
            <option value="7">7</option>
            <option value="14">14</option>
            <option value="30" selected>30</option>
            <option value="60">60</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Unidade (base)</label>
        <input class="form-control" id="filterUnidade" placeholder="Ex.: DES8" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Status do contrato</label>
        <input class="form-control" id="filterStatus" placeholder="(opcional)" />
    </div>
    <div class="col-md-3 d-flex gap-2">
        <div class="form-check mt-4">
            <input class="form-check-input" type="checkbox" id="autoRefresh" checked>
            <label class="form-check-label" for="autoRefresh">Atualização automática</label>
        </div>
        <button class="btn btn-outline-primary mt-3" id="refreshBtn">Atualizar</button>
    </div>
</div>

<div class="alert alert-danger d-none alert-inline" id="dashError"></div>

<div class="row g-3">
    <div class="col-lg-3">
        <div class="card kpi-card" id="cardCreate">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted">Criar teste</div>
                        <div class="fs-3 fw-semibold" id="kpiSpecs">-</div>
                    </div>
                    <span class="badge text-bg-primary">specs</span>
                </div>
                <div class="mt-2" id="chartSpecs"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card kpi-card" id="cardSearch">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted">Buscar testes</div>
                        <div class="fs-3 fw-semibold" id="kpiSacs">-</div>
                    </div>
                    <span class="badge text-bg-secondary">SACs</span>
                </div>
                <div class="mt-2" id="chartSearch"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card kpi-card" id="cardVideo">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted">Rodar vídeo</div>
                        <div class="fs-3 fw-semibold" id="kpiVideos">-</div>
                    </div>
                    <span class="badge text-bg-success">webm</span>
                </div>
                <div class="mt-2" id="chartVideos"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3">
        <div class="card kpi-card" id="cardConfig">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="text-muted">Configuração</div>
                        <div class="fs-3 fw-semibold">Config</div>
                    </div>
                    <span class="badge text-bg-dark">.env</span>
                </div>
                <div class="mt-2" id="chartConfig"></div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 text-muted" id="lastRefresh"></div>

@section Scripts {
<script>
(function(){
  const $ = (id) => document.getElementById(id);
  const err = $("dashError");

  const cardCreate = $("cardCreate");
  const cardSearch = $("cardSearch");
  const cardVideo = $("cardVideo");
  const cardConfig = $("cardConfig");

  cardCreate.addEventListener('click', () => location.href = '/CreateTest');
  cardSearch.addEventListener('click', () => location.href = '/SearchTests');
  cardVideo.addEventListener('click', () => location.href = '/Videos');
  cardConfig.addEventListener('click', () => location.href = '/Config');

  async function load(){
    window.topSaude.clearAlert(err);
    const days = parseInt($("periodDays").value || '30', 10);

    const summary = await window.topSaude.apiFetch(`/api/summary`);

    $("kpiSpecs").textContent = summary.totalSpecs;
    $("kpiSacs").textContent = summary.totalSacs;
    $("kpiVideos").textContent = summary.totalVideos;

    const onDrill = (p) => {
      const from = p.x + 'T00:00:00Z';
      const to = p.x + 'T23:59:59Z';
      location.href = `/SearchTests?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}`;
    };

    window.topSaude.renderMiniChart($("chartSpecs"), summary.specsByDay.slice(-days).map(x => ({ date: x.date, count: x.count })), onDrill);
    window.topSaude.renderMiniChart($("chartSearch"), summary.specsByDay.slice(-days).map(x => ({ date: x.date, count: x.count })), onDrill);
    window.topSaude.renderMiniChart($("chartVideos"), summary.videosByDay.slice(-days).map(x => ({ date: x.date, count: x.count })), (p) => {
      const from = p.x + 'T00:00:00Z';
      const to = p.x + 'T23:59:59Z';
      location.href = `/Videos?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}`;
    });

    renderConfigBars(summary);

    $("lastRefresh").textContent = 'Atualizado em ' + new Date().toLocaleString();
  }

  function renderConfigBars(summary){
    const container = $("chartConfig");
    const width = container.clientWidth || 320;
    const height = 56;
    const pad = 6;

    const items = [
      { label: 'Specs', value: summary.totalSpecs, color: '#0d6efd' },
      { label: 'Vídeos', value: summary.totalVideos, color: '#198754' },
      { label: 'SACs', value: summary.totalSacs, color: '#6c757d' },
    ];

    const max = Math.max(1, ...items.map(i => i.value));
    const barW = (width - pad * 2) / items.length;

    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
    svg.setAttribute('class', 'mini-chart');

    items.forEach((it, idx) => {
      const h = Math.round(((height - pad*2) * it.value) / max);
      const x = pad + idx * barW + 4;
      const y = height - pad - h;
      const rect = document.createElementNS(svg.namespaceURI, 'rect');
      rect.setAttribute('x', x);
      rect.setAttribute('y', y);
      rect.setAttribute('width', Math.max(8, barW - 8));
      rect.setAttribute('height', h);
      rect.setAttribute('rx', 3);
      rect.setAttribute('fill', it.color);
      rect.style.opacity = '0.85';

      svg.appendChild(rect);
    });

    container.innerHTML = '';
    container.appendChild(svg);
  }

  let timer = null;

  async function refresh(){
    try{ await load(); }
    catch(e){ window.topSaude.setAlert(err, e.message || String(e), 'alert-danger'); }
  }

  function schedule(){
    if (timer) clearInterval(timer);
    if (!$("autoRefresh").checked) return;
    timer = setInterval(refresh, 30000);
  }

  $("refreshBtn").addEventListener('click', refresh);
  $("autoRefresh").addEventListener('change', schedule);
  $("periodDays").addEventListener('change', refresh);

  refresh();
  schedule();
})();
</script>
}
