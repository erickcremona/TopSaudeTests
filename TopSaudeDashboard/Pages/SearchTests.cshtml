@page
@model TopSaudeDashboard.Pages.SearchTestsModel
@{
    ViewData["Title"] = "Buscar testes";
}

<div class="d-flex justify-content-between align-items-start mb-2">
    <div>
        <h2 class="mb-1">Buscar testes</h2>
        <div class="text-muted">Navegue por `tests/{SAC_XXXXXX}` e execute specs em modo visual.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-success" id="btnExport" href="#">Exportar Excel</a>
        <button class="btn btn-outline-primary" id="btnRefresh">Atualizar</button>
    </div>
</div>

<div class="alert alert-danger d-none alert-inline" id="searchError"></div>

<div class="row g-3 mb-2">
    <div class="col-md-3">
        <label class="form-label">De (UTC)</label>
        <input class="form-control" type="datetime-local" id="from" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Até (UTC)</label>
        <input class="form-control" type="datetime-local" id="to" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Unidade (base)</label>
        <input class="form-control" id="unidade" placeholder="Ex.: DES8" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Status do contrato</label>
        <input class="form-control" id="statusContrato" placeholder="(opcional)" />
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-3">
        <div class="card">
            <div class="card-body sidebar">
                <div class="fw-semibold mb-2">SACs</div>
                <div class="list-group" id="sacList"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold mb-2" id="filesTitle">Arquivos .spec.ts</div>
                <div class="table-responsive" style="max-height: 70vh; overflow:auto;">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Arquivo</th>
                                <th class="text-end">Atualizado (UTC)</th>
                            </tr>
                        </thead>
                        <tbody id="filesBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold mb-1">Executar</div>
                <div class="text-muted mb-2" id="selectedFile">Selecione um .spec.ts</div>

                <div class="d-flex gap-2 mb-2">
                    <select class="form-select" id="runMode" style="max-width: 160px;" disabled>
                        <option value="headed" selected>headed</option>
                        <option value="ui">ui</option>
                    </select>
                    <button class="btn btn-primary" id="btnRun" disabled>Rodar teste</button>
                </div>

                <div class="text-muted" id="jobStatus"></div>
                <pre class="code-box" id="jobLog">Aguardando...</pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function(){
  const $ = (id) => document.getElementById(id);
  const err = $("searchError");

  let specs = [];
  let sacEntries = [];
  let selectedSac = null;
  let selectedSpecPath = null;
  let sse = null;

  function toLocalInputValue(date){
    const pad = (n) => String(n).padStart(2,'0');
    return date.getUTCFullYear() + '-' + pad(date.getUTCMonth()+1) + '-' + pad(date.getUTCDate()) + 'T' + pad(date.getUTCHours()) + ':' + pad(date.getUTCMinutes());
  }

  function fromLocalInputValue(value){
    if (!value) return null;
    // value is like 2026-03-21T12:34 (interpreted as local by browser);
    // we treat it as UTC to avoid timezone confusion.
    return value + ':00Z';
  }

  function queryParams(){
    const from = fromLocalInputValue($("from").value);
    const to = fromLocalInputValue($("to").value);
    const unidade = $("unidade").value.trim();
    const statusContrato = $("statusContrato").value.trim();

    const qs = new URLSearchParams();
    if (from) qs.set('from', from);
    if (to) qs.set('to', to);
    if (unidade) qs.set('unidade', unidade);
    if (statusContrato) qs.set('statusContrato', statusContrato);
    return qs;
  }

  function renderSacList(){
    const bySac = {};

    specs.forEach(s => {
      if (!s.sac) return;
      if (!s.path.startsWith('tests/' + s.sac + '/')) return;

      const ms = Date.parse(s.lastWriteTime || '');
      if (!bySac[s.sac]) bySac[s.sac] = { count: 0, latestMs: -1, latestText: null };
      bySac[s.sac].count++;
      if (!Number.isNaN(ms) && ms > bySac[s.sac].latestMs) {
        bySac[s.sac].latestMs = ms;
        bySac[s.sac].latestText = s.lastWriteTime || null;
      }
    });

    const list = $("sacList");
    list.innerHTML = '';

    sacEntries = Object.keys(bySac)
      .map(sac => ({ sac, count: bySac[sac].count, latestMs: bySac[sac].latestMs, latestText: bySac[sac].latestText }))
      .sort((a, b) => {
        const diff = (b.latestMs - a.latestMs);
        if (diff !== 0) return diff;
        return a.sac.localeCompare(b.sac);
      });

    if (sacEntries.length === 0) {
      list.innerHTML = '<div class="text-muted">Nenhum SAC encontrado.</div>';
      return;
    }

    sacEntries.forEach(entry => {
      const a = document.createElement('a');
      a.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
      a.href = '#';
      a.textContent = entry.sac;
      if (entry.latestText) a.title = 'Mais recente (UTC): ' + entry.latestText;

      const badge = document.createElement('span');
      badge.className = 'badge text-bg-secondary rounded-pill';
      badge.textContent = entry.count;
      a.appendChild(badge);

      a.addEventListener('click', (e) => {
        e.preventDefault();
        selectedSac = entry.sac;
        selectedSpecPath = null;
        $("selectedFile").textContent = 'Selecione um .spec.ts';
        $("btnRun").disabled = true;
        $("runMode").disabled = true;

        // reset do painel de execucao ao trocar de SAC
        if (sse) { try { sse.close(); } catch {} sse = null; }
        $("jobStatus").textContent = '';
        $("jobLog").textContent = 'Aguardando...';

        renderFiles();
        Array.from(list.querySelectorAll('a')).forEach(x => x.classList.remove('active'));
        a.classList.add('active');
      });

      list.appendChild(a);
    });
  }

  function renderFiles(){
    const body = $("filesBody");
    body.innerHTML = '';

    if (!selectedSac){
      $("filesTitle").textContent = 'Arquivos .spec.ts';
      return;
    }

    $("filesTitle").textContent = `tests/${selectedSac}`;

    const list = specs
      .filter(s => s.sac === selectedSac)
      .filter(s => s.path.startsWith('tests/' + selectedSac + '/'))
      .filter(s => s.path.endsWith('.spec.ts'))
      .sort((a,b) => (b.lastWriteTime || '').localeCompare(a.lastWriteTime || ''));

    list.forEach(s => {
      const tr = document.createElement('tr');
      tr.className = 'file-row';
      tr.innerHTML = `<td>${escapeHtml(s.fileName)}</td><td class="text-end"><span class="text-muted">${(s.lastWriteTime||'').replace('Z','')}</span></td>`;
      tr.addEventListener('click', () => {
        selectedSpecPath = s.path;
        $("selectedFile").textContent = s.path;
        $("btnRun").disabled = false;
        $("runMode").disabled = false;
        Array.from(body.querySelectorAll('tr')).forEach(x => x.classList.remove('table-primary'));
        tr.classList.add('table-primary');
      });
      body.appendChild(tr);
    });

    if (list.length === 0) {
      const tr = document.createElement('tr');
      tr.innerHTML = '<td colspan="2" class="text-muted">Nenhum .spec.ts encontrado para este SAC.</td>';
      body.appendChild(tr);
    }
  }

  function escapeHtml(str){
    return (str || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
  }

  async function refresh(){
    window.topSaude.clearAlert(err);

    const qs = queryParams();
    const data = await window.topSaude.apiFetch('/api/specs?' + qs.toString());

    specs = data || [];
    renderSacList();

    if (!selectedSac) {
      selectedSac = sacEntries.length > 0 ? sacEntries[0].sac : null;

      if (selectedSac) {
        const first = $("sacList").querySelector('a');
        if (first) first.classList.add('active');
      }
    }

    renderFiles();

    $("btnExport").href = '/api/specs/export?' + qs.toString();
  }

  async function run(){
    window.topSaude.clearAlert(err);

    if (!selectedSpecPath) {
      window.topSaude.setAlert(err, 'Selecione um .spec.ts.', 'alert-danger');
      return;
    }

    $("jobLog").textContent = '';
    $("jobStatus").textContent = 'Executando...';

    const mode = $("runMode").value;
    const job = await window.topSaude.apiFetch('/api/specs/run', {
      method: 'POST',
      body: JSON.stringify({ path: selectedSpecPath, mode })
    });

    if (sse) sse.close();
    sse = window.topSaude.connectJobSse(job.id, (line) => {
      const el = $("jobLog");
      el.textContent += line + "\n";
      el.scrollTop = el.scrollHeight;
    }, async () => {
      const state = await window.topSaude.apiFetch(`/api/jobs/${encodeURIComponent(job.id)}`);
      $("jobStatus").textContent = state.info.state;
      if (state.info.state === 2) window.topSaude.setAlert(err, state.info.error || 'Falha ao rodar.', 'alert-danger');
    });
  }

  $("btnRefresh").addEventListener('click', () => refresh().catch(e => window.topSaude.setAlert(err, e.message, 'alert-danger')));
  $("btnRun").addEventListener('click', () => run().catch(e => window.topSaude.setAlert(err, e.message, 'alert-danger')));

  // init filters from query string
  const q = new URLSearchParams(location.search);
  const fromQ = q.get('from');
  const toQ = q.get('to');
  if (fromQ) $("from").value = fromQ.replace('Z','').slice(0,16);
  if (toQ) $("to").value = toQ.replace('Z','').slice(0,16);

  refresh().catch(e => window.topSaude.setAlert(err, e.message, 'alert-danger'));
})();
</script>
}


